// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum GameStatus {
  LOBBY
  ACTIVE
  COMPLETED
  CANCELLED
}

enum WinCategory {
  EARLY_5
  TOP_LINE
  MIDDLE_LINE
  BOTTOM_LINE
  FULL_HOUSE
}

enum QueueStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum UserRole {
  PLAYER
  ORGANIZER
}

// Models
model User {
  id           String   @id @default(uuid())
  email        String?  @unique // Made optional for mobile-only users
  password     String?          // Made optional for OTP-only users
  name         String?          // Made optional
  role         UserRole @default(PLAYER)
  mobileNumber String?  @unique // For OTP-based login
  countryCode  String?  @default("+91")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([mobileNumber])
}

model Game {
  id            String             @id @default(uuid())
  scheduledTime DateTime
  startedAt     DateTime?
  endedAt       DateTime?
  status        GameStatus         @default(LOBBY)
  createdBy     String
  prizes        Json
  calledNumbers Int[]              @default([])
  currentNumber Int?
  isPublic      Boolean            @default(true) // All games are open to all users by default
  lobbyPlayers  GameLobbyPlayer[]  // Players in waiting lobby
  players       Player[]           // Players with tickets (after game starts)
  winners       Winner[]
  prizeQueue    PrizeQueue[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([scheduledTime, status])
  @@index([createdBy])
}

model GameLobbyPlayer {
  id        String   @id @default(uuid())
  gameId    String
  userId    String
  userName  String
  joinedAt  DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([gameId])
}

model Player {
  id        String   @id @default(uuid())
  gameId    String
  userId    String
  userName  String
  ticket    Json     // Store full 3x9 grid structure as JSON
  joinedAt  DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  winners   Winner[]

  @@unique([gameId, userId])
  @@index([gameId, userId])
}

model Winner {
  id           String      @id @default(uuid())
  gameId       String
  playerId     String
  category     WinCategory
  claimedAt    DateTime    @default(now())
  prizeClaimed Boolean     @default(false)
  prizeValue   Json?
  game         Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player       Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([gameId, category])
  @@index([prizeClaimed])
}

model PrizeQueue {
  id             String      @id @default(uuid())
  userId         String
  gameId         String
  category       WinCategory
  prizeValue     Json
  status         QueueStatus @default(PENDING)
  attempts       Int         @default(0)
  lastAttempt    DateTime?
  error          String?
  idempotencyKey String?     // Track external API idempotency
  game           Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([userId, gameId, category])  // Prevent duplicate prize entries
  @@index([status, createdAt])
  @@index([userId])
}

model PromotionalBanner {
  id          String   @id @default(uuid())
  imageUrl    String
  s3Key       String?
  uploadedBy  String?
  width       Int?
  height      Int?
  fileSize    Int?
  altText     String?
  linkUrl     String?
  isActive    Boolean  @default(true)
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, displayOrder])
}

model YouTubeEmbed {
  id          String   @id @default(uuid())
  videoId     String   @unique
  embedId     String?
  videoUrl    String?
  title       String?
  description String?
  isActive    Boolean  @default(true)
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, displayOrder])
}

model YouTubeLiveStream {
  id          String   @id @default(uuid())
  embedId     String   @unique
  videoUrl    String?
  uploadedBy  String?
  title       String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

model RegistrationCard {
  id             String   @id @default(uuid())
  message        String
  targetDateTime DateTime
  isActive       Boolean  @default(true)
  lastResetAt    DateTime @default(now())
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
}

// Solo Game Mode Enums
enum SoloGameStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum SoloWeekStatus {
  ACTIVE
  FINALIZED
}

// Solo Game Mode Models
model SoloWeek {
  id            String         @id @default(uuid())
  weekStartDate DateTime       // Monday 00:00:00 IST
  weekEndDate   DateTime       // Saturday 23:59:59 IST
  status        SoloWeekStatus @default(ACTIVE)
  finalizedAt   DateTime?

  // Game 1 — Video-based number calling configuration
  videoUrl         String?              // Full YouTube URL
  videoId          String?              // Extracted YouTube video ID for embed
  numberSequence   Int[]    @default([]) // Shared 1-90 order for the week
  numberTimestamps Float[]  @default([]) // Computed timestamp (seconds) per number
  videoStartTime   Float?               // Seconds into video when 1st number called
  numberInterval   Float?               // Seconds between each number call
  configuredAt     DateTime?            // When organizer configured this week
  configuredBy     String?              // Organizer userId

  // Game 2 — Separate video config (optional, configured independently)
  game2VideoUrl         String?
  game2VideoId          String?
  game2NumberSequence   Int[]    @default([])
  game2NumberTimestamps Float[]  @default([])
  game2VideoStartTime   Float?
  game2ConfiguredAt     DateTime?
  game2ConfiguredBy     String?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  games         SoloGame[]
  winners       SoloWeeklyWinner[]

  @@unique([weekStartDate])
  @@index([status])
}

model SoloGame {
  id              String         @id @default(uuid())
  userId          String
  weekId          String
  gameNumber      Int            @default(1)  // 1 = Game 1, 2 = Game 2
  ticket          Json           // 3x9 grid, same format as Player.ticket
  numberSequence  Int[]          // Pre-shuffled 1-90 array
  markedNumbers   Int[]          @default([]) // Numbers user has marked on ticket
  status          SoloGameStatus @default(IN_PROGRESS)
  currentIndex    Int            @default(0)  // How far the auto-caller has progressed
  startedAt       DateTime       @default(now())
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  week            SoloWeek       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  claims          SoloClaim[]

  @@unique([userId, weekId, gameNumber])  // One game per user per week per gameNumber
  @@index([userId])
  @@index([weekId])
  @@index([status])
}

model SoloClaim {
  id                 String      @id @default(uuid())
  soloGameId         String
  category           WinCategory
  numberCountAtClaim Int         // How many numbers had been called (1-indexed)
  claimedAt          DateTime    @default(now())

  soloGame           SoloGame    @relation(fields: [soloGameId], references: [id], onDelete: Cascade)

  @@unique([soloGameId, category])  // One claim per category per game
  @@index([soloGameId])
  @@index([category, numberCountAtClaim])
}

model SoloWeeklyWinner {
  id                 String      @id @default(uuid())
  weekId             String
  category           WinCategory
  gameNumber         Int            @default(1)  // 1 = Game 1, 2 = Game 2
  userId             String
  userName           String?
  numberCountAtClaim Int
  claimedAt          DateTime
  createdAt          DateTime    @default(now())

  week               SoloWeek    @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([weekId, category, gameNumber])  // One winner per category per week per game
  @@index([weekId])
}
